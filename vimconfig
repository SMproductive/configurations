"Plug 'junegunn/fzf.vim'
Plug 'vim-test/vim-test' "TODO kotlin and go
call plug#end()
	"coc.vim
let g:coc_global_extensions = ['coc-json', 'coc-git', 'coc-clangd',
			\ 'coc-go', 'coc-pyright', 'coc-html', 'coc-css']
inoremap <silent><expr> <TAB>
      \ pumvisible() ? "\<C-n>" :
      \ <SID>check_back_space() ? "\<TAB>" :
      \ coc#refresh()
inoremap <expr><S-TAB> pumvisible() ? "\<C-p>" : "\<C-h>"
if has('nvim')
  inoremap <silent><expr> <c-space> coc#refresh()
else
  inoremap <silent><expr> <c-@> coc#refresh()
endif
nmap <silent> gd <Plug>(coc-definition)
nmap <silent> gy <Plug>(coc-type-definition)
nmap <silent> gi <Plug>(coc-implementation)
nmap <silent> gr <Plug>(coc-references)
nmap rn <Plug>(coc-rename)
xmap <leader>f  <Plug>(coc-format-selected)
nmap <leader>f  <Plug>(coc-format-selected)
nnoremap <silent><nowait> <space>a  :<C-u>CocList diagnostics<cr>

function! s:check_back_space() abort
  let col = col('.') - 1
  return !col || getline('.')[col - 1]  =~# '\s'
endfunction
	"vim-maximizer
map <leader>m :MaximizerToggle<Enter>
	"vim-test
let test#strategy='vimterminal'
let test#go#runner = 'ginkgo'
let test#java#runner = 'gradletest'
let test#kotlin#runner = 'gradletest'

let test#vim#term_position = "belowright 10"
nmap <silent> tn :TestNearest<Enter>
nmap <silent> tf :TestFile<Enter>
nmap <silent> ts :TestSuite<Enter>
nmap <silent> tl :TestLast<Enter>
nmap <silent> tv :TestVisit<Enter>
