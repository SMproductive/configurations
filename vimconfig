"general things
map <leader>c <Esc>:!
filetype on
filetype plugin indent on
syntax on
set updatetime=1000
set tabstop=4
set shiftwidth=4
set spell
set breakindent
set clipboard=unnamedplus
set incsearch "highlights search
set number
set cursorline
set wildmode=longest,list,full
colorscheme nord
autocmd InsertEnter * norm 5jzz5k
autocmd BufWritePre * %s/\s\+$//e
"general bindings
imap gg <Esc>
nnoremap da ggVGd
	"splits
map <C-n> <Esc>:vnew<Enter>
map <C-h> <C-w>h
map <C-j> <C-w>j
map <C-k> <C-w>k
map <C-l> <C-w>l
"code editing helpers
imap {{ {<Enter>}<Esc>ko
imap (( ()<++><Esc>4hi
imap [[ []<++><Esc>4hi
nnoremap <Del> %d``dl
"imap kk <Esc>/<++><Enter>"_c4l does not work anymore
imap "" ""<++><Esc>4hi
imap '' ''<++><Esc>4hi
imap <> <><++><Esc>4hi
imap jj <++>
	"c
autocmd FileType c,cpp
	\ set cindent
autocmd FileType c,cpp
	\ imap // /*  */<Esc>2hi
autocmd FileType c,cpp
	\ imap if<Enter> <Esc>:read ~/code/if.c<Enter>kdd=2jikk
autocmd FileType c,cpp
	\ imap for<Enter> <Esc>:read ~/code/for.c<Enter>kdd=2jikk
autocmd FileType c,cpp
	\ imap while<Enter> <Esc>:read~/code/while.c<Enter>kdd=2jikk
"html
autocmd FileType html,css
	\ set tabstop=2
autocmd FileType html,css
	\ set shiftwidth=2

"ready to code
nnoremap ,c :read ~/code/empty.c<Enter>kdd2jo
nnoremap ,cpp :read ~/code/empty.cpp<Enter>kdd2jo
nnoremap ,bash :read ~/code/empty.bash<Enter>kddo
nnoremap ,html :read ~/code/empty.html<Enter>kdd4j3wa
"timestamp in second line of file
nnoremap t 2ggddk:pu=strftime('%c')<Enter>==

